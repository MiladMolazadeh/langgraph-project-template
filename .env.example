# ── LLM provider ─────────────────────────────────────────────────────────────
# Options: deepseek | openai | openrouter
LLM_PROVIDER=openrouter

# Leave blank to use provider default (deepseek-v4-flash / gpt-4o / etc.)
LLM_MODEL=
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096

# ── API keys (only the key for your chosen provider is required) ──────────────
DEEPSEEK_API_KEY=your_deepseek_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── LangSmith (optional — tracing enabled when LANGCHAIN_TRACING_V2=true) ────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=my-langgraph-project

# ── Langfuse (optional — requires: uv add langfuse) ──────────────────────────
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_HOST=https://cloud.langfuse.com
